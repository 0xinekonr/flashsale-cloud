# ============================================================
# Docker Compose 环境变量模板
# 用途: 供 docker-compose.yml 中 ${VAR} 引用
# 使用: 复制为 .env 并填入实际值
# 注意: 此文件与根目录 .env.example 不同，此处变量供 Docker 容器使用
# ============================================================

# MySQL 配置 (Nacos/Seata 容器连接宿主机 MySQL)
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DB_FLASHSALE=flashsale_config

# Nacos 配置
NACOS_AUTH_TOKEN=your_nacos_auth_token

# RabbitMQ 配置
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=your_rabbitmq_password

# Grafana 配置
GF_ADMIN_PASSWORD=your_grafana_password
